{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "appcheck": {
    "providers": {
      "recaptcha_enterprise": {
        "siteKey": "YOUR_RECAPTCHA_ENTERPRISE_SITE_KEY"
      }
    },
    "apps": {
      "web:mr-chatting-ff2b6": {
        "provider": "recaptcha_enterprise",
        "unsetFilesAllowedFor": []
      }
    }
  }
}
